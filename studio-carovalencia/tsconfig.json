{
  "compilerOptions": {
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2017",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["."]
}
